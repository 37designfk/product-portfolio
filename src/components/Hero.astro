---
import { products } from '../data/products';

const totalProducts = products.length;
const aiProducts = products.filter(p => p.category === 'product-ai' || p.tech.some(t => t.toLowerCase().includes('ai') || t.toLowerCase().includes('claude'))).length;
const activeProducts = products.filter(p => p.status === '稼働中' || p.status === '管理中').length;
const clientProjects = products.filter(p => p.category.startsWith('client')).length;
---

<section class="relative pt-32 pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-accent/5 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-purple-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-accent text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-accent animate-pulse"></span>
      {totalProducts} Projects & Counting
    </div>

    <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-6">
      <span class="text-text">つくったもの、</span><br>
      <span class="bg-gradient-to-r from-accent via-purple-500 to-pink-500 bg-clip-text text-transparent">
        ぜんぶ見せます。
      </span>
    </h1>

    <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      自社プロダクト・クライアント案件 — <br class="sm:hidden">
      AI・SaaS・Web・モバイルアプリ全プロジェクト一覧
    </p>

    <div class="flex flex-wrap justify-center gap-8 text-center">
      <div>
        <div class="text-3xl sm:text-4xl font-black text-text">{totalProducts}</div>
        <div class="text-sm text-text-muted mt-1">全プロジェクト</div>
      </div>
      <div class="w-px bg-border"></div>
      <div>
        <div class="text-3xl sm:text-4xl font-black text-text">{aiProducts}</div>
        <div class="text-sm text-text-muted mt-1">AI搭載</div>
      </div>
      <div class="w-px bg-border"></div>
      <div>
        <div class="text-3xl sm:text-4xl font-black text-text">{clientProjects}</div>
        <div class="text-sm text-text-muted mt-1">クライアント案件</div>
      </div>
      <div class="w-px bg-border"></div>
      <div>
        <div class="text-3xl sm:text-4xl font-black text-text">{activeProducts}</div>
        <div class="text-sm text-text-muted mt-1">稼働中</div>
      </div>
    </div>
  </div>
</section>
