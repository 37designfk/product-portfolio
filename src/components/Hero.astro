---
---

<section class="relative pt-32 pb-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <!-- Background effects -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute -top-40 -right-40 w-96 h-96 bg-accent/10 rounded-full blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 bg-purple-500/10 rounded-full blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-gradient-to-r from-accent/5 to-purple-500/5 rounded-full blur-3xl"></div>
  </div>

  <div class="relative max-w-4xl mx-auto text-center">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-accent/10 border border-accent/20 text-accent-light text-sm font-medium mb-8">
      <span class="w-2 h-2 rounded-full bg-accent-light animate-pulse"></span>
      12 Products & Counting
    </div>

    <h1 class="text-4xl sm:text-6xl lg:text-7xl font-black tracking-tight leading-[1.1] mb-6">
      <span class="text-white">つくったもの、</span><br>
      <span class="bg-gradient-to-r from-accent-light via-purple-400 to-pink-400 bg-clip-text text-transparent">
        ぜんぶ見せます。
      </span>
    </h1>

    <p class="text-lg sm:text-xl text-text-muted max-w-2xl mx-auto mb-10 leading-relaxed">
      AI・SaaS・モバイルアプリ — <br class="sm:hidden">
      自社で企画・開発・運用しているプロダクトの一覧です。
    </p>

    <div class="flex flex-wrap justify-center gap-8 text-center">
      <div>
        <div class="text-3xl sm:text-4xl font-black text-white">12</div>
        <div class="text-sm text-text-muted mt-1">プロダクト</div>
      </div>
      <div class="w-px bg-white/10"></div>
      <div>
        <div class="text-3xl sm:text-4xl font-black text-white">8</div>
        <div class="text-sm text-text-muted mt-1">AI搭載</div>
      </div>
      <div class="w-px bg-white/10"></div>
      <div>
        <div class="text-3xl sm:text-4xl font-black text-white">5</div>
        <div class="text-sm text-text-muted mt-1">稼働中</div>
      </div>
    </div>
  </div>
</section>
