---
import type { Product } from '../data/products';
import ProductIcon from './ProductIcon.astro';

interface Props {
  product: Product;
  index: number;
}

const { product, index } = Astro.props;
---

<article
  class="group relative bg-white rounded-2xl border border-border overflow-hidden hover:border-accent/30 transition-all duration-500 hover:-translate-y-1 hover:shadow-xl hover:shadow-accent/5"
  style={`animation-delay: ${index * 80}ms`}
  data-category={product.category}
  data-id={product.id}
>
  <!-- Screenshot area -->
  <div class={`relative h-48 bg-gradient-to-br ${product.gradient} overflow-hidden`}>
    {product.screenshot ? (
      <img
        src={product.screenshot}
        alt={`${product.name} スクリーンショット`}
        class="w-full h-full object-cover object-top"
        loading="lazy"
      />
    ) : (
      <div class="absolute inset-0 flex items-center justify-center">
        <div class="text-center">
          <ProductIcon icon={product.icon} class="w-16 h-16 text-white/80 mx-auto mb-2" />
          <span class="text-white/50 text-xs font-medium">Screenshot Coming Soon</span>
        </div>
        <div class="absolute inset-0 opacity-10">
          <div class="absolute inset-0" style="background-image: radial-gradient(circle, white 1px, transparent 1px); background-size: 24px 24px;"></div>
        </div>
      </div>
    )}

    <!-- Status badge -->
    <div class="absolute top-4 right-4">
      <span class={`inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-semibold text-white ${product.statusColor} shadow-lg`}>
        <span class="w-1.5 h-1.5 rounded-full bg-white/80"></span>
        {product.status}
      </span>
    </div>

    <!-- Category badge -->
    <div class="absolute top-4 left-4">
      <span class="px-2.5 py-1 rounded-full text-xs font-medium text-white/90 bg-black/30 backdrop-blur-sm">
        {product.categoryLabel}
      </span>
    </div>
  </div>

  <!-- Content -->
  <div class="p-6">
    <div class="flex items-start justify-between gap-2">
      <h3 class="text-xl font-bold text-text mb-1 group-hover:text-accent transition-colors">
        {product.url ? (
          <a href={product.url} target="_blank" rel="noopener noreferrer" class="hover:underline inline-flex items-center gap-1.5">
            {product.name}
            <svg class="w-4 h-4 text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
        ) : product.name}
      </h3>
    </div>

    <p class="text-sm font-medium text-accent mb-3">{product.tagline}</p>
    <p class="text-sm text-text-muted leading-relaxed mb-4">{product.description}</p>

    <!-- Tech stack -->
    <div class="flex flex-wrap gap-1.5 mb-4">
      {product.tech.map((t) => (
        <span class="px-2 py-0.5 rounded-md text-[11px] font-medium bg-surface text-text-muted border border-border">
          {t}
        </span>
      ))}
    </div>

    <!-- Features -->
    <div class="grid grid-cols-2 gap-1.5 mb-4">
      {product.features.map((f) => (
        <div class="flex items-center gap-1.5 text-xs text-text-muted">
          <svg class="w-3.5 h-3.5 text-accent shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
          </svg>
          {f}
        </div>
      ))}
    </div>

    <!-- URL button -->
    {product.url && (
      <a
        href={product.url}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 px-4 py-2 rounded-lg bg-accent/10 border border-accent/20 text-accent text-sm font-medium hover:bg-accent/20 transition-colors w-full justify-center"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
        </svg>
        サイトを見る
      </a>
    )}
  </div>
</article>
